# cv_processor/fraud_detector.py

import numpy as np
from sklearn.ensemble import IsolationForest
from sklearn.preprocessing import StandardScaler
import re
from datetime import datetime, timedelta
import hashlib
import json

class FraudDetector:
    def __init__(self):
        self.isolation_forest = IsolationForest(
            contamination=0.1,
            random_state=42
        )
        self.scaler = StandardScaler()
        self._fraud_patterns = self._load_fraud_patterns()
        
    def _load_fraud_patterns(self):
        """Load known fraud patterns"""
        return {
            'ai_generated_indicators': [
                r'as a large language model',
                r'I am an AI',
                r'generated by',
                r'proficient in a wide range of',
                r'adept at leveraging',
            ],
            'impossible_combinations': [
                r'22.*years.*experience',
                r'fresh graduate.*senior',
                r'student.*(CISSP|CISM)',
            ]
        }
    
    def detect_ai_generated(self, text):
        """Check for AI-generated text patterns"""
        text_lower = text.lower()
        ai_score = 0
        for pattern in self._fraud_patterns['ai_generated_indicators']:
            if re.search(pattern, text_lower):
                ai_score += 1
        return min(ai_score / len(self._fraud_patterns['ai_generated_indicators']), 1.0)
    
    def detect_certification_fraud(self, certifications, age):
        """Detect certification fraud based on age and experience"""
        risk_score = 0
        if not certifications:
            return 0.0
        
        for cert in certifications:
            # Check if certification requires experience
            experience_required = {
                'CISSP': 5,
                'CISM': 5,
                'CISA': 5,
                'OSCP': 0,  # No experience required, but exam is hard
                'CEH': 0,
                'CompTIA Security+': 0
            }
            
            cert_name = cert.get('name', '')
            for known_cert, exp_req in experience_required.items():
                if known_cert in cert_name:
                    # If candidate is too young for experience-required cert
                    if age < exp_req + 21:  # Minimum age 21 + experience required
                        risk_score += 0.5
            
            # Check for missing verification ID (common in fake certs)
            if 'verification_id' not in cert or not cert['verification_id']:
                risk_score += 0.3
        
        return min(risk_score, 1.0)
    
    def detect_experience_inflation(self, experience_years, graduation_year, current_year=None):
        """Detect inflated experience claims"""
        if current_year is None:
            current_year = datetime.now().year
        
        if not graduation_year:
            return 0.0
        
        max_possible_experience = max(0, current_year - graduation_year)
        
        if experience_years > max_possible_experience:
            inflation = (experience_years - max_possible_experience) / max_possible_experience if max_possible_experience > 0 else 1.0
            return min(inflation, 1.0)
        
        return 0.0
    
    def detect_duplicate_cv(self, cv_hash, existing_hashes):
        """Check if CV is duplicate"""
        if cv_hash in existing_hashes:
            return 1.0
        return 0.0
    
    def compute_cv_hash(self, text):
        """Compute hash of CV text for duplicate detection"""
        # Normalize text (remove extra whitespace, lower case)
        normalized = ' '.join(text.lower().split())
        return hashlib.sha256(normalized.encode()).hexdigest()
    
    def detect_skill_inconsistency(self, skills, text):
        """Detect inconsistent skill claims"""
        # If skill is mentioned in CV but not in extracted skills
        text_lower = text.lower()
        skill_scores = {}
        
        for skill in skills:
            # Check if skill is actually present in text context
            if skill in text_lower:
                # Check surrounding context for "proficient", "expert", "advanced"
                context_patterns = [r'proficient', r'expert', r'advanced', r'experienced']
                skill_context_score = 0
                for pattern in context_patterns:
                    if re.search(f"{pattern}.*{skill}|{skill}.*{pattern}", text_lower):
                        skill_context_score += 1
                skill_scores[skill] = skill_context_score
        
        # If many skills have no context, suspicious
        low_context_count = sum(1 for score in skill_scores.values() if score == 0)
        if len(skills) > 0:
            return low_context_count / len(skills)
        return 0.0
    
    def calculate_fraud_score(self, parsed_data, age, graduation_year, existing_cv_hashes):
        """Calculate overall fraud score"""
        fraud_factors = []
        weights = {
            'ai_generated': 0.25,
            'certification_fraud': 0.20,
            'experience_inflation': 0.20,
            'skill_inconsistency': 0.15,
            'duplicate_cv': 0.20
        }
        
        # 1. AI-generated text detection
        ai_score = self.detect_ai_generated(parsed_data.get('cv_text', ''))
        fraud_factors.append({
            'factor': 'AI Generated Text',
            'score': ai_score,
            'weight': weights['ai_generated'],
            'details': f"AI detection score: {ai_score:.2f}"
        })
        
        # 2. Certification fraud
        cert_score = self.detect_certification_fraud(
            parsed_data.get('certifications', []),
            age
        )
        fraud_factors.append({
            'factor': 'Certification Fraud',
            'score': cert_score,
            'weight': weights['certification_fraud'],
            'details': f"Certification risk score: {cert_score:.2f}"
        })
        
        # 3. Experience inflation
        exp_score = self.detect_experience_inflation(
            parsed_data.get('experience_years', 0),
            graduation_year
        )
        fraud_factors.append({
            'factor': 'Experience Inflation',
            'score': exp_score,
            'weight': weights['experience_inflation'],
            'details': f"Experience inflation score: {exp_score:.2f}"
        })
        
        # 4. Skill inconsistency
        skill_score = self.detect_skill_inconsistency(
            parsed_data.get('skills', []),
            parsed_data.get('cv_text', '')
        )
        fraud_factors.append({
            'factor': 'Skill Inconsistency',
            'score': skill_score,
            'weight': weights['skill_inconsistency'],
            'details': f"Skill inconsistency score: {skill_score:.2f}"
        })
        
        # 5. Duplicate CV
        cv_hash = self.compute_cv_hash(parsed_data.get('cv_text', ''))
        dup_score = self.detect_duplicate_cv(cv_hash, existing_cv_hashes)
        fraud_factors.append({
            'factor': 'Duplicate CV',
            'score': dup_score,
            'weight': weights['duplicate_cv'],
            'details': f"Duplicate score: {dup_score:.2f}"
        })
        
        # Calculate weighted total
        total_score = sum(f['score'] * f['weight'] for f in fraud_factors)
        
        return {
            'fraud_score': round(total_score, 3),
            'fraud_score_percentage': f"{round(total_score * 100, 1)}%",
            'risk_level': self._get_risk_level(total_score),
            'factors': fraud_factors,
            'cv_hash': cv_hash,
            'flagged_sections': self._get_flagged_sections(fraud_factors)
        }
    
    def _get_risk_level(self, score):
        if score >= 0.7:
            return 'High'
        elif score >= 0.4:
            return 'Medium'
        else:
            return 'Low'
    
    def _get_flagged_sections(self, factors):
        flagged = []
        for f in factors:
            if f['score'] > 0.4:
                flagged.append({
                    'section': f['factor'],
                    'reason': f['details'],
                    'severity': 'High' if f['score'] > 0.7 else 'Medium'
                })
        return flagged
        
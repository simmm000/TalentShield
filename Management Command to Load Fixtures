# gamification/management/commands/load_challenges.py

from django.core.management.base import BaseCommand
from django.core.management import call_command

class Command(BaseCommand):
    help = 'Load initial challenges and achievements data'

    def handle(self, *args, **options):
        self.stdout.write('Loading challenges...')
        call_command('loaddata', 'gamification/fixtures/initial_challenges.json')
        self.stdout.write('Loading achievements...')
        call_command('loaddata', 'gamification/fixtures/initial_achievements.json')
        self.stdout.write(self.style.SUCCESS('Successfully loaded initial data!'))
        